{
  "search": {
    "description": "搜尋設定",
    "type": "object",
    "items": {
      "enable_llm_tool": {
        "description": "啟用 AI 自動搜尋工具",
        "hint": "開啟後 AI 可自行判斷是否需要呼叫 web_search 聯網搜尋",
        "type": "bool",
        "default": true
      },
      "enable_command": {
        "description": "啟用 /search 指令",
        "type": "bool",
        "default": true
      },
      "default_limit": {
        "description": "預設搜尋結果數",
        "type": "int",
        "slider": {
          "min": 1,
          "max": 10,
          "step": 1
        },
        "default": 5
      },
      "enable_page_fetch": {
        "description": "允許 AI 抓取搜尋結果頁面內容",
        "hint": "開啟後 AI 可在需要時讀取網頁文字；會比只看摘要更消耗 token",
        "type": "bool",
        "default": true
      },
      "default_fetch_pages": {
        "description": "最多抓取幾個搜尋結果頁面",
        "type": "int",
        "slider": {
          "min": 0,
          "max": 10,
          "step": 1
        },
        "default": 2
      }
    }
  }
}
